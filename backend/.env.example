# Application
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# Database
DB_URL=sqlite+aiosqlite:///./botbuilder.db
# Production: DB_URL=postgresql+asyncpg://user:pass@localhost/botbuilder
DB_ECHO=false
DB_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=your-256-bit-secret-key-change-me-now-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Telegram
TELEGRAM_PLATFORM_BOT_TOKEN=your-platform-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-change-me
TELEGRAM_WEBHOOK_BASE_URL=https://your-domain.com

# Security — CHANGE IN PRODUCTION
SECURITY_ENCRYPTION_KEY=your-exactly-32-char-encryption!!
SECURITY_RATE_LIMIT_PER_MINUTE=60

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Observability
OBSERVABILITY_SENTRY_DSN=
OBSERVABILITY_LOG_LEVEL=INFO
